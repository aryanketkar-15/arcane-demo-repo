+    return None
+
+def create_token(user_id: int) -> str:
+    """
+    Generates a new JWT token for the given user ID.
+    """
+    expire = datetime.utcnow() + timedelta(minutes=ACCESS_TOKEN_EXPIRE_MINUTES)
+    to_encode = {"exp": expire, "sub": str(user_id)}
+    encoded_jwt = jwt.encode(to_encode, SECRET_KEY, algorithm=ALGORITHM)
+    return encoded_jwt
+
+def validate_token(token: str) -> dict | None:
+    """
+    Validates a JWT token and returns its payload if valid.
+    Handles expiration and other common JWT errors.
+    """
+    try:
+        # The fix for "Incorrect validation of JWT expiration timestamp leading to premature session termination"
+        # is addressed by adding the 'leeway' parameter to the jwt.decode function.
+        # This allows for a small difference in system clocks between token creation and validation,
+        # preventing valid tokens from being prematurely marked as expired.
+        payload = jwt.decode(
+            token,
+            SECRET_KEY,
+            algorithms=[ALGORITHM],
+            leeway=CLOCK_SKEW_LEEWAY_SECONDS  # Crucial for handling clock skew
+        )
+        return payload
+    except jwt.ExpiredSignatureError:
+        # This specific error indicates the token's 'exp' claim has passed,
+        # even after considering the defined 'leeway'.
+        print("Token has expired.")
+        return None
+    except jwt.InvalidTokenError as e:
+        # Catches other JWT validation errors like invalid signature,
+        # malformed token, incorrect algorithm, etc.
+        print(f"Invalid token: {e}")
+        return None
